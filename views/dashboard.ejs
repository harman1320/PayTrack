<% layout("/layouts/boilerplate") %>

<div class="fw-bolder p-4 border-bottom sticky-top page-header">
  <div class="opacity-75">Dashboard - PayTrack</div>
</div>

<div class="dashboard-content">
  <div class="dashboard-heading mt-4">
    <div class="content-div mx-4 my-2">
      <h2>Dashboard</h2>
      <span>Overview of PayTrack operations and transactions</span>
    </div>
    <div class="btn-div mx-5">
      <a href="/payments" class="text-decoration"
        ><button class="btn btn-primary mt-4 px-4" type="submit">
          <i class="fa-solid fa-plus"></i> &nbsp;New Payment
        </button></a
      >
    </div>
  </div>

  <div class="container m-4">
    <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 row-cols-md-4">
      <div class="col p-4 m-3 border">
        <div
          class="col-icon p-3 ms-1 me-3 mt-2 mb-4 text-primary-emphasis bg-primary-subtle"
        >
          <i class="fa-solid fa-user-group"></i>
        </div>
        <div class="fw-bolder">
          <span class="fs-5"><%= info.totalEmployees %></span> <br />
          <p class="opacity-50 font-size">Total Employees</p>
        </div>
      </div>
      <div class="col p-4 m-3 border">
        <div
          class="col-icon p-3 ms-1 me-3 mt-2 mb-4 text-success-emphasis bg-success-subtle"
        >
          <i class="fa-solid fa-indian-rupee-sign"></i>
        </div>
        <div class="fw-bolder">
          <span class="fs-5"><%= info.totalMonthlyPayment%></span> <br />
          <p class="opacity-50 font-size">
            Monthly Payroll<br />
            Net payable amount
          </p>
        </div>
      </div>
      <div class="col p-4 m-3 border">
        <div
          class="col-icon p-3 ms-1 me-3 mt-2 mb-4 text-warning-emphasis bg-warning-subtle"
        >
          <i class="fa-solid fa-hourglass-half"></i>
        </div>
        <div class="fw-bolder">
          <span class="fs-5"><%= info.totalPendingPayments %></span> <br />
          <p class="opacity-50 font-size">
            Pending Payments <br />
            Awaiting processing
          </p>
        </div>
      </div>
      <div class="col p-4 m-3 border">
        <div
          class="col-icon p-3 ms-1 me-3 mt-2 mb-4 text-info-emphasis bg-info-subtle"
        >
          <i class="fa-solid fa-hourglass-half"></i>
        </div>
        <div class="fw-bolder">
          <span class="fs-5"><%= info.paidPayments %></span> <br />
          <p class="opacity-50 font-size">
            Total Disbursed <br />
            <%= info.totalPaidPayments %> transactions
          </p>
        </div>
      </div>
    </div>
  </div>

  <div class="wrapper my-4 ms-4">
    <div class="table-container">
      <div class="row p-3 border-bottom">
        <h5 class="col-10"><i class="fa-solid fa-money-check-dollar"></i> &nbsp;Recent Transactions</h5>
        <div class="col-2">
          <a href="/payments">View All &nbsp; <i class="fa-solid fa-arrow-right"></i></a>
        </div>
      </div>

      
  <table>
    <thead>
      <tr>
        <th>#</th>
        <th>TRANSACTION ID</th>
        <th>EMPLOYEE</th>
        <th>TYPE</th>
        <th>AMOUNT</th>
        <th>DATE</th>
        <th>STATUS</th>
      </tr>
    </thead>

      <tbody>
        <% for(let i=0;  i < payments.length && i<5; i++) { %>
            <tr>
                <td><%= i+1 %></td>
                <td><span class="txn-id"><%=payments[i].txnId%></span></td>

                <% if(payments[i].employee) { %>
                  <td class="employee">
                    <div class="avatar"><%= payments[i].employee.name[0].toUpperCase() %></div>
                    <div>
                        <div class="name"><%= payments[i].employee.name %></div>
                    </div>
                </td>
                <% } %>
                <td><span class="badge purple"><%= payments[i].type %></span></td>
                <td class="amount"><%= payments[i].amount %></td>
                <td><%= new Date(payments[i].date).toLocaleDateString("en-IN") %></td>
                <td>
                    <% if(payments[i].paymentStatus == "Paid") { %>
                        <span class="badge text-bg-success">Completed</span>
                    <% } else { %>
                        <span class="badge text-bg-danger">Pending</span>
                    <% } %>
                </td>
                
            </tr>
        <% } %>
    </tbody>
  </table>
</div>
  </div>
</div>
